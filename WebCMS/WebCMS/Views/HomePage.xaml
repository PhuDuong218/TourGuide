<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourGuideMauiApp.Views.HomePage"
             Title="Gian hàng">

    <ScrollView>
        <VerticalStackLayout Padding="10" Spacing="15">

            <!-- Banner -->
            <Frame BackgroundColor="#2196F3" CornerRadius="15">
                <Label Text="GIAN HÀNG DU LỊCH"
                       FontSize="22"
                       TextColor="White"
                       HorizontalOptions="Center"/>
            </Frame>

            <!-- Danh mục -->
            <Label Text="Danh mục" FontSize="18" FontAttributes="Bold"/>

            <HorizontalStackLayout Spacing="10">
                <Button Text="Đồ ăn"/>
                <Button Text="Đồ uống"/>
                <Button Text="Đặc sản"/>
            </HorizontalStackLayout>

            <!-- Sản phẩm -->
            <Label Text="Sản phẩm nổi bật" FontSize="18" FontAttributes="Bold"/>

            <CollectionView x:Name="ProductList">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="5" Padding="10">
                            <VerticalStackLayout>
                                <Image Source="{Binding Image}" HeightRequest="100"/>
                                <Label Text="{Binding Name}" FontSize="16"/>
                                <Label Text="{Binding Price}" TextColor="Red"/>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>