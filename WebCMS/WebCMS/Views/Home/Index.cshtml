@model WebCMS.Models.DashboardViewModel
@{
    ViewData["Title"] = "Bảng điều khiển";
}

<div class="row g-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3" style="border-left: 5px solid #6f42c1 !important;">
            <div class="text-muted small fw-bold">TỔNG NGÔN NGỮ</div>
            <div class="d-flex justify-content-between align-items-center mt-2">
                <h2 class="fw-bold mb-0">@Model.TotalLanguages</h2>
                <i class="fa-solid fa-language text-purple fs-3"></i>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3" style="border-left: 5px solid #198754 !important;">
            <div class="text-muted small fw-bold">TỔNG SỐ QR</div>
            <div class="d-flex justify-content-between align-items-center mt-2">
                <h2 class="fw-bold mb-0">@Model.TotalQR</h2>
                <i class="fa-solid fa-qrcode text-success fs-3"></i>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3" style="border-left: 5px solid #ffc107 !important;">
            <div class="text-muted small fw-bold">LƯỢT QUÉT QR</div>
            <div class="d-flex justify-content-between align-items-center mt-2">
                <h2 class="fw-bold mb-0">@Model.TotalQRScans</h2>
                <i class="fa-solid fa-bolt text-warning fs-3"></i>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3" style="border-left: 5px solid #0dcaf0 !important;">
            <div class="text-muted small fw-bold">LƯỢT SỬ DỤNG APP</div>
            <div class="d-flex justify-content-between align-items-center mt-2">
                <h2 class="fw-bold mb-0">@Model.TotalAppUsage</h2>
                <i class="fa-solid fa-headphones text-info fs-3"></i>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3" style="border-left: 5px solid #0d6efd !important;">
            <div class="text-muted small fw-bold">ĐANG TRUY CẬP (REAL-TIME)</div>
            <div class="d-flex justify-content-between align-items-center mt-2">
                <h2 class="fw-bold mb-0" id="active-count-val" style="color: #0d6efd;">@Model.ActiveToday</h2>
                <i class="fa-solid fa-user-check text-primary fs-3"></i>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm p-4">
            <h5 class="fw-bold mb-4" style="color: #1e40af;">
                <i class="fa-solid fa-chart-line me-2"></i>Xu hướng sử dụng 7 ngày qua
            </h5>
            <div style="height: 300px;">
                <canvas id="usageChart"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4 mb-5">
    <div class="col-12">
        <div class="card border-0 shadow-sm p-4">
            <h5 class="fw-bold mb-4" style="color: #1e40af;">
                <i class="fa-solid fa-chart-simple me-2"></i>Top 5 Địa điểm được nghe nhiều nhất
            </h5>
            <div style="height: 350px;">
                <canvas id="topPoiChart"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function() {

            // ==========================================
            // 1. CHỨC NĂNG REAL-TIME (SIGNALR)
            // ==========================================
            try {
                // Đổi URL này nếu link devtunnels của Server bạn bị thay đổi
                const hubConnection = new signalR.HubConnectionBuilder()
                    .withUrl("https://gzm4vrwg-7054.asse.devtunnels.ms/activeUserHub")
                    .withAutomaticReconnect()
                    .build();

                hubConnection.on("UpdateOnlineCount", function (count) {
                    console.log("SignalR: Nhận được số người dùng mới ->", count);
                    const element = document.getElementById('active-count-val');
                    if (element) {
                        element.innerText = count;
                        // Hiệu ứng nháy xanh
                        element.style.transition = "color 0.3s";
                        element.style.color = "#22c55e";
                        setTimeout(() => element.style.color = "#0d6efd", 1000);
                    }
                });

                hubConnection.start()
                    .then(() => console.log("SignalR: Đã kết nối thành công tới Server!"))
                    .catch(err => console.error("SignalR: Lỗi kết nối ->", err));
            } catch (e) {
                console.error("Lỗi khởi tạo SignalR:", e);
            }

            // ==========================================
            // 2. BIỂU ĐỒ XU HƯỚNG 7 NGÀY
            // ==========================================
            try {
                // Gán dữ liệu C# ra biến JS an toàn
                const trendLabels = @Html.Raw(Json.Serialize(Model?.TrendLabels ?? new List<string>()));
                const installTrend = @Html.Raw(Json.Serialize(Model?.InstallTrend ?? new List<int>()));
                const activeTrend = @Html.Raw(Json.Serialize(Model?.ActiveTrend ?? new List<int>()));
                const scanTrend = @Html.Raw(Json.Serialize(Model?.ScanTrend ?? new List<int>()));

                const usageCtx = document.getElementById('usageChart').getContext('2d');
                new Chart(usageCtx, {
                    type: 'line',
                    data: {
                        labels: trendLabels,
                        datasets: [
                            { label: 'Cài đặt', data: installTrend, borderColor: '#3b82f6', backgroundColor: '#3b82f6', tension: 0.3, fill: false },
                            { label: 'Hoạt động', data: activeTrend, borderColor: '#10b981', backgroundColor: '#10b981', tension: 0.3, fill: false },
                            { label: 'Quét QR', data: scanTrend, borderColor: '#f59e0b', backgroundColor: '#f59e0b', tension: 0.3, fill: false }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { position: 'top' } }
                    }
                });
            } catch (e) { console.error("Lỗi vẽ biểu đồ Line:", e); }

            // ==========================================
            // 3. BIỂU ĐỒ TOP 5 ĐỊA ĐIỂM
            // ==========================================
            try {
                const chartLabels = @Html.Raw(Json.Serialize(Model?.ChartLabels ?? new List<string>()));
                const chartValues = @Html.Raw(Json.Serialize(Model?.ChartValues ?? new List<int>()));

                const topCtx = document.getElementById('topPoiChart').getContext('2d');
                new Chart(topCtx, {
                    type: 'bar',
                    data: {
                        labels: chartLabels,
                        datasets: [{
                            label: 'Lượt nghe',
                            data: chartValues,
                            backgroundColor: ['#7dd3fc', '#f9a8d4', '#fde047', '#5eead4', '#c4b5fd'],
                            borderRadius: 4
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } }
                    }
                });
            } catch (e) { console.error("Lỗi vẽ biểu đồ Bar:", e); }

        });
    </script>
}