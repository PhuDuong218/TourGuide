@model WebCMS.Models.DashboardViewModel
@{
    ViewData["Title"] = "Bảng điều khiển";
}

<div class="row g-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3" style="border-left: 5px solid #6f42c1 !important;">
            <div class="text-muted small fw-bold">TỔNG NGÔN NGỮ</div>
            <div class="d-flex justify-content-between align-items-center mt-2">
                <h2 class="fw-bold mb-0">@Model.TotalLanguages</h2>
                <i class="fa-solid fa-language text-purple fs-3"></i>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3" style="border-left: 5px solid #198754 !important;">
            <div class="text-muted small fw-bold">TỔNG SỐ POI</div>
            <div class="d-flex justify-content-between align-items-center mt-2">
                <h2 class="fw-bold mb-0">@Model.TotalPOI</h2>
                <i class="fa-solid fa-location-dot text-success fs-3"></i>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3" style="border-left: 5px solid #ffc107 !important;">
            <div class="text-muted small fw-bold">TỔNG MÃ QR</div>
            <div class="d-flex justify-content-between align-items-center mt-2">
                <h2 class="fw-bold mb-0">@Model.TotalQR</h2>
                <i class="fa-solid fa-qrcode text-warning fs-3"></i>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3" style="border-left: 5px solid #0dcaf0 !important;">
            <div class="text-muted small fw-bold">TỔNG LƯỢT NGHE</div>
            <div class="d-flex justify-content-between align-items-center mt-2">
                <h2 class="fw-bold mb-0">@Model.TotalListens</h2>
                <i class="fa-solid fa-headphones text-info fs-3"></i>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3" style="border-left: 5px solid #0d6efd !important;">
            <div class="text-muted small fw-bold">ĐANG TRUY CẬP (REAL-TIME)</div>
            <div class="d-flex justify-content-between align-items-center mt-2">
                <h2 class="fw-bold mb-0" id="active-count-val" style="color: #0d6efd;">@Model.ActiveToday</h2>
                <i class="fa-solid fa-user-check text-primary fs-3"></i>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4 mb-5">
    <div class="col-12">
        <div class="card border-0 shadow-sm p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold mb-0" style="color: #1e40af;">
                    <i class="fa-solid fa-chart-simple me-2"></i>Top 5 Địa điểm được nghe nhiều nhất
                </h5>
            </div>
            <div style="height: 350px;">
                <canvas id="topPoiChart"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function() {

            // ==========================================
            // 1. CHỨC NĂNG REAL-TIME (SIGNALR)
            // ==========================================
            try {
                const hubConnection = new signalR.HubConnectionBuilder()
                    .withUrl("https://gzm4vrwg-7054.asse.devtunnels.ms/activeUserHub")
                    .withAutomaticReconnect()
                    .build();

                hubConnection.on("UpdateOnlineCount", function (count) {
                    const element = document.getElementById('active-count-val');
                    if (element) {
                        element.innerText = count;
                        element.style.transition = "color 0.3s";
                        element.style.color = "#22c55e";
                        setTimeout(() => element.style.color = "#0d6efd", 1000);
                    }
                });

                hubConnection.start().catch(err => console.error("SignalR Lỗi:", err));
            } catch (e) {
                console.error("Lỗi SignalR:", e);
            }

            // ==========================================
            // 2. BIỂU ĐỒ TOP 5 VÀ LỌC THỜI GIAN
            // ==========================================
            let topPoiChartInstance = null;

            // Hàm vẽ biểu đồ
            function renderTopPoiChart(labels, values) {
                const topCtx = document.getElementById('topPoiChart').getContext('2d');

                // Xóa biểu đồ cũ nếu có để vẽ cái mới
                if (topPoiChartInstance) {
                    topPoiChartInstance.destroy();
                }

                topPoiChartInstance = new Chart(topCtx, {
                    type: 'bar',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: 'Lượt nghe',
                            data: values,
                            backgroundColor: ['#7dd3fc', '#f9a8d4', '#fde047', '#5eead4', '#c4b5fd'],
                            borderRadius: 4
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } }
                    }
                });
            }

            try {
                const initialLabels = JSON.parse('@Html.Raw(Json.Serialize(Model?.ChartLabels ?? new List<string>()))');
                const initialValues = JSON.parse('@Html.Raw(Json.Serialize(Model?.ChartValues ?? new List<int>()))');
                renderTopPoiChart(initialLabels, initialValues);
            } catch (e) { console.error("Lỗi load biểu đồ mặc định:", e); }

            

        });
    </script>
}