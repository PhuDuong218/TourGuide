@model List<WebCMS.Models.POIDTO>

@{
    ViewData["Title"] = "Quản lý điểm du lịch";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Danh sách điểm du lịch (POI)</h2>
        <a href="/POI/Create" class="btn btn-primary shadow-sm">+ Thêm POI mới</a>
    </div>

    <div class="card shadow">
        <div class="card-body">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Tên địa điểm</th>
                        <th>Phân loại</th>
                        <th>Mô tả</th>
                        <th>Vĩ độ (Lat)</th>
                        <th>Kinh độ (Lng)</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var p in Model)
                        {
                            <tr>
                                <td class="fw-bold">@p.POIID</td>
                                <td>@p.Name</td>
                                <td>@p.CategoryName</td>
                                <td>@p.Description</td>
                                <td>@p.Latitude</td>
                                <td>@p.Longitude</td>
                                <td class="text-center">
                                    <a href="/POI/Translations/@p.POIID" class="btn btn-sm btn-outline-info">Xem nội dung</a>
                                    <span class="mx-1">|</span>
                                    <a href="/POI/Delete/@p.POIID" class="btn btn-sm btn-outline-danger"
                                       onclick="return confirm('Bạn có chắc chắn muốn xóa địa điểm này?')">Xóa</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted">Chưa có dữ liệu nào để hiển thị.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>