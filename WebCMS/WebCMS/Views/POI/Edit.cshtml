@model WebCMS.Models.POI
@{
    ViewData["Title"] = "Sửa địa điểm";
}

<div style="max-width:760px">
    <a asp-controller="POI" asp-action="Index" class="btn-outline-admin" style="margin-bottom:10px;display:inline-flex">
        <i class="fa-solid fa-arrow-left"></i> Danh sách POI
    </a>

    <div class="form-card">
        <div style="margin-bottom:28px">
            <h2 style="font-size:18px;font-weight:800;color:var(--text)">Sửa địa điểm</h2>
            <p style="font-size:13px;color:var(--text-muted);margin-top:4px">
                Cập nhật thông tin địa điểm <strong>@Model.RestaurantName</strong>.
                Để trống phần ảnh nếu không muốn thay đổi ảnh hiện tại.
            </p>
        </div>

        <!-- ✅ FIX: dùng POIID -->
        <form asp-action="Edit" asp-route-id="@Model.POIID" method="post" enctype="multipart/form-data">

            <!-- giữ ảnh cũ -->
            <input type="hidden" asp-for="Img" />

            <div class="form-group">
                <label class="form-label-admin">Tên địa điểm *</label>
                <input asp-for="RestaurantName" class="form-control-admin" placeholder="VD: Chùa Cầu, Hội An" required />
            </div>

            <div class="form-grid-2">
                <div class="form-group">
                    <label class="form-label-admin">Phân loại *</label>
                    <select asp-for="Category" class="form-control-admin" required>
                        <option value="">-- Chọn phân loại --</option>
                        <option value="Quán ăn / Ẩm thực">Quán ăn / Ẩm thực</option>
                        <option value="Di tích lịch sử">Di tích lịch sử</option>
                        <option value="Bảo tàng">Bảo tàng</option>
                        <option value="Chợ / Mua sắm">Chợ / Mua sắm</option>
                        <option value="Tâm linh / Tôn giáo">Tâm linh / Tôn giáo</option>
                        <option value="Danh lam thắng cảnh">Danh lam thắng cảnh</option>
                        <option value="Giải trí / Công viên">Giải trí / Công viên</option>
                        <option value="Khác">Khác</option>
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label-admin">Loại</label>
                    <select asp-for="Type" class="form-control-admin">
                        <option value="">-- Chọn loại --</option>
                        <option value="MAIN">Điểm chính (MAIN)</option>
                        <option value="WC">WC</option>
                        <option value="TICKET">Bán vé</option>
                        <option value="PARKING">Gửi xe</option>
                        <option value="BOAT">Bến thuyền</option>
                    </select>
                </div>
            </div>

            <div class="form-grid-2">
                <div class="form-group">
                    <label class="form-label-admin">Vĩ độ (Latitude) *</label>
                    <input asp-for="Latitude" type="number" step="0.000001" class="form-control-admin" required />
                </div>

                <div class="form-group">
                    <label class="form-label-admin">Kinh độ (Longitude) *</label>
                    <input asp-for="Longitude" type="number" step="0.000001" class="form-control-admin" required />
                </div>
            </div>

            <div class="form-group">
                <label class="form-label-admin">Địa chỉ</label>
                <input asp-for="Address" class="form-control-admin" placeholder="VD: 1 Nguyễn Thị Minh Khai, Hội An" />
            </div>

            <!-- ẢNH -->
            <div class="form-group">
                <label class="form-label-admin">Ảnh hiện tại</label>

                @if (!string.IsNullOrEmpty(Model.Img))
                {
                    <div style="margin-bottom:10px">
                        <img src="https://gzm4vrwg-7054.asse.devtunnels.ms/uploads/@Model.Img"
                             alt="@Model.RestaurantName"
                             style="height:120px;border-radius:8px;border:1px solid var(--border);object-fit:cover" />

                        <div style="font-size:12px;color:var(--text-muted);margin-top:4px">
                            <i class="fa-solid fa-file-image"></i> @Model.Img
                        </div>
                    </div>
                }
                else
                {
                    <div style="margin-bottom:10px;color:var(--text-muted);font-size:13px">
                        <i class="fa-solid fa-image"></i> Chưa có ảnh
                    </div>
                }

                <label class="form-label-admin">Thay ảnh mới (không bắt buộc)</label>
                <input type="file" name="imageFile" class="form-control-admin"
                       id="imageInput" accept="image/*" />

                <div class="form-hint">Chọn file mới để thay ảnh. Bỏ trống để giữ ảnh cũ.</div>

                <div id="imagePreview" style="margin-top:10px;display:none">
                    <img id="previewImg" src="" alt="Preview"
                         style="height:120px;border-radius:8px;border:1px solid var(--border);object-fit:cover" />
                    <div style="font-size:12px;color:#22c55e;margin-top:4px">
                        <i class="fa-solid fa-check"></i> Ảnh mới sẽ được lưu khi bấm Cập nhật
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label-admin">Bán kính geofence (m)</label>
                <input asp-for="Radius" type="number" class="form-control-admin" min="10" max="500" />
                <div class="form-hint">Phạm vi kích hoạt thuyết minh khi khách đến gần.</div>
            </div>

            <div class="form-group">
                <label class="form-label-admin">Mức độ ưu tiên (Sao)</label>
                <select asp-for="Priority" class="form-control-admin">
                    <option value="1">1 Sao</option>
                    <option value="2">2 Sao</option>
                    <option value="3">3 Sao</option>
                    <option value="4">4 Sao</option>
                    <option value="5">5 Sao</option>
                </select>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-primary-admin">
                    <i class="fa-solid fa-floppy-disk"></i> Cập nhật
                </button>
                <a asp-controller="POI" asp-action="Index" class="btn-outline-admin">Hủy</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('imageInput').addEventListener('change', function (e) {
            const file = e.target.files[0];
            const preview = document.getElementById('imagePreview');
            const img = document.getElementById('previewImg');

            if (file) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    img.src = e.target.result;
                    preview.style.display = 'block';
                };
                reader.readAsDataURL(file);
            } else {
                preview.style.display = 'none';
            }
        });
    </script>
}