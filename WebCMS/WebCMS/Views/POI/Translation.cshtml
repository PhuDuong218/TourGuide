@model IEnumerable<WebCMS.Models.POITranslation>
@{
    ViewData["Title"] = "Nội dung đa ngôn ngữ";
    var langs = Model?.Select(t => t.LanguageCode).ToList() ?? new List<string>();

    // CHỈ GIỮ 4 NGÔN NGỮ
    var allLangs = new[] { "vi", "en", "fr", "ja" };
    var langFlags = new Dictionary<string, string> {
        {"vi","🇻🇳"}, {"en","🇬🇧"}, {"fr","🇫🇷"}, {"ja","🇯🇵"}
    };
}

<div class="page-header">
    <div class="page-header-left">
        <a asp-controller="POI" asp-action="Index" class="btn-outline-admin" style="margin-bottom:10px;display:inline-flex">
            <i class="fa-solid fa-arrow-left"></i> Danh sách POI
        </a>
        <h1>Bản dịch — POI #@ViewBag.POIID</h1>
        <p>Quản lý nội dung thuyết minh theo từng ngôn ngữ</p>
    </div>
    <a href="/POI/AddTranslation?poiId=@ViewBag.POIID" class="btn-primary-admin">
        <i class="fa-solid fa-plus"></i> Thêm bản dịch
    </a>
</div>

<div class="admin-card" style="margin-bottom:20px;padding:18px 24px">
    <div style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.6px;color:var(--text-muted);margin-bottom:10px">
        Ngôn ngữ đã có
    </div>
    <div style="display:flex;gap:8px;flex-wrap:wrap">
        @foreach (var l in allLangs)
        {
            var has = langs.Contains(l);
            <span class="lang-chip" style="@(has ? "background:var(--accent-light);border-color:var(--accent-border);color:var(--accent)" : "")">
                @(langFlags.GetValueOrDefault(l, "🌐")) @l.ToUpper()
                @if (has)
                {
                    <i class="fa-solid fa-check" style="font-size:10px"></i>
                }
                else
                {
                    <i class="fa-solid fa-xmark" style="font-size:10px;color:var(--text-light)"></i>
                }
            </span>
        }
    </div>
</div>

<div class="admin-card">
    <div class="admin-card-header">
        <span class="admin-card-title">Danh sách bản dịch (@langs.Count)</span>
    </div>
    <div class="admin-card-body">
        @if (Model != null && Model.Any())
        {
            <table class="admin-table">
                <thead>
                    <tr>
                        <th style="width:120px">Ngôn ngữ</th>
                        <th>Tên hiển thị</th>
                        <th>Nội dung thuyết minh</th>
                        <th style="width:120px;text-align:center">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model)
                    {
                        <tr>
                            <td>
                                <span class="lang-chip" style="background:var(--accent-light);border-color:var(--accent-border);color:var(--accent)">
                                    @(langFlags.GetValueOrDefault(t.LanguageCode, "🌐")) @t.LanguageCode.ToUpper()
                                </span>
                            </td>
                            <td>
                                <div style="font-weight:600;color:var(--text)">@t.DisplayName</div>
                                <div style="font-size:12px;color:var(--text-muted)">@t.ShortDescription</div>
                            </td>
                            <td>
                                <span class="narration-preview" style="display:block;max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                                    @t.NarrationText
                                </span>
                            </td>
                            <td style="text-align:center;">
                                <div style="display:flex; gap:10px; justify-content:center;">
                                    <a href="/POI/EditTranslation?poiId=@t.POIID&lang=@t.LanguageCode" class="btn-icon-admin" style="color:#0ea5e9; font-size:18px" title="Sửa bản dịch">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </a>
                                    <a href="/POI/DeleteTranslation?poiId=@t.POIID&lang=@t.LanguageCode" class="btn-icon-admin danger" style="color:#ef4444; font-size:18px" onclick="return confirm('Bạn có chắc chắn muốn xóa bản dịch @t.LanguageCode.ToUpper() này không?')" title="Xóa bản dịch">
                                        <i class="fa-solid fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="empty-state">
                <div class="empty-icon"><i class="fa-solid fa-language"></i></div>
                <h3>Chưa có bản dịch nào</h3>
                <p>Thêm nội dung thuyết minh bằng tiếng Việt trước, rồi các ngôn ngữ khác.</p>
                <a href="/POI/AddTranslation?poiId=@ViewBag.POIID" class="btn-primary-admin">
                    <i class="fa-solid fa-plus"></i> Thêm bản dịch đầu tiên
                </a>
            </div>
        }
    </div>
</div>