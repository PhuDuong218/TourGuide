<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GPS Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        body { background-color: #f4f7fe; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; overflow: hidden; }
        
        /* Cấu trúc chính chia đôi: Sidebar và Content */
        .wrapper { display: flex; height: 100vh; width: 100vw; }

        /* Sidebar màu xanh đặc trưng */
        .sidebar { 
            width: 260px; 
            background: #004581; 
            color: white; 
            display: flex; 
            flex-direction: column; 
            transition: all 0.3s;
            box-shadow: 4px 0 10px rgba(0,0,0,0.1);
        }

        .sidebar-header { padding: 30px 25px; font-size: 1.5rem; font-weight: 800; letter-spacing: 1px; }

        .nav-menu { flex: 1; padding: 10px 15px; }

        .nav-item-custom { 
            display: flex; 
            align-items: center; 
            padding: 12px 15px; 
            color: rgba(255,255,255,0.7); 
            text-decoration: none; 
            margin-bottom: 5px; 
            border-radius: 10px;
            transition: 0.2s;
        }

        .nav-item-custom i { margin-right: 12px; font-size: 1.1rem; width: 25px; text-align: center; }

        .nav-item-custom:hover, .nav-item-custom.active { 
            background: rgba(255,255,255,0.15); 
            color: white; 
            font-weight: 600;
        }

        .sidebar-footer { padding: 20px; border-top: 1px solid rgba(255,255,255,0.1); }

        /* Vùng nội dung chính bên phải */
        .main-content { 
            flex: 1; 
            overflow-y: auto; 
            padding: 40px; 
            display: flex; 
            flex-direction: column; 
        }

        /* Tùy chỉnh thanh cuộn */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-thumb { background: #d1d9e6; border-radius: 10px; }
    </style>
</head>
<body>
    <div class="wrapper">
        <!-- Sidebar bên trái -->
        <nav class="sidebar">
            <div class="sidebar-header">
                <i class="fa-solid fa-location-dot me-2"></i> GPS ADMIN
            </div>
            
            <div class="nav-menu">
                <a href="/POI" class="nav-item-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "POI" ? "active" : "")">
                    <i class="fa-solid fa-map-location-dot"></i> Quản lý điểm (POIs)
                </a>
                <a href="/Tours" class="nav-item-custom">
                    <i class="fa-solid fa-route"></i> Quản lý Tours
                </a>
                @* <a href="/Map" class="nav-item-custom">
                    <i class="fa-solid fa-earth-asia"></i> Bản đồ trực quan
                </a>
                <a href="/Settings" class="nav-item-custom">
                    <i class="fa-solid fa-gear"></i> Cấu hình hệ thống
                </a> *@
            </div>

            <div class="sidebar-footer">
                <a href="/Account/Logout" class="nav-item-custom text-warning">
                    <i class="fa-solid fa-right-from-bracket"></i> Đăng xuất (Logout)
                </a>
            </div>
        </nav>

        <!-- Vùng hiển thị nội dung các trang con (Index, Create,...) -->
        <main class="main-content">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>