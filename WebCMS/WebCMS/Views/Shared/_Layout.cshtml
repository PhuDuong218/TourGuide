@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    var ctx = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
}

<!DOCTYPE html>

<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GPS Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/admin.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="shell">

        <aside class="sidebar" id="sidebar">
            <div class="sidebar-brand">
                <div class="brand-icon"><i class="fa-solid fa-location-dot"></i></div>
                <div class="brand-text">
                    <span class="brand-name">GPS Admin</span>
                    <span class="brand-sub">Tour Management</span>
                </div>
            </div>

            <div class="sidebar-section-label">Tổng quan</div>
            <nav class="sidebar-nav">
                <a asp-controller="Home" asp-action="Index" class="nav-link-item @(ctx == "Home" ? "active" : "")">
                    <span class="nav-icon"><i class="fa-solid fa-chart-pie"></i></span>
                    <span class="nav-label">Bảng điều khiển</span>
                </a>
            </nav>

            <div class="sidebar-section-label">Nội dung</div>
            <nav class="sidebar-nav">

                @* OWNER *@
                @if (User.IsInRole("owner"))
                {
                    <a asp-controller="POI" asp-action="Index" class="nav-link-item @(ctx == "POI" ? "active" : "")">
                        <span class="nav-icon"><i class="fa-solid fa-map-pin"></i></span>
                        <span class="nav-label">POI của tôi</span>
                    </a>

                    <a asp-controller="QRCode" asp-action="Index" class="nav-link-item @(ctx == "QRCode" ? "active" : "")">
                        <span class="nav-icon"><i class="fa-solid fa-qrcode"></i></span>
                        <span class="nav-label">Mã QR</span>
                    </a>
                }

                @* ADMIN *@
                @if (User.IsInRole("admin"))
                {
                    <a asp-controller="POI" asp-action="Index" class="nav-link-item @(ctx == "POI" ? "active" : "")">
                        <span class="nav-icon"><i class="fa-solid fa-map-pin"></i></span>
                        <span class="nav-label">Tất cả POI</span>
                    </a>

                    <a asp-controller="QRCode" asp-action="Index" class="nav-link-item @(ctx == "QRCode" ? "active" : "")">
                        <span class="nav-icon"><i class="fa-solid fa-qrcode"></i></span>
                        <span class="nav-label">Mã QR</span>
                    </a>
                }

            </nav>

            <div class="sidebar-section-label">Phân tích</div>
            <nav class="sidebar-nav">

                @if (User.IsInRole("owner"))
                {
                    <a asp-controller="VisitHistory" asp-action="Index" class="nav-link-item @(ctx == "VisitHistory" ? "active" : "")">
                        <span class="nav-icon"><i class="fa-solid fa-chart-line"></i></span>
                        <span class="nav-label">Lịch sử của tôi</span>
                    </a>
                }

                @if (User.IsInRole("admin"))
                {
                    <a asp-controller="VisitHistory" asp-action="Index" class="nav-link-item @(ctx == "VisitHistory" ? "active" : "")">
                        <span class="nav-icon"><i class="fa-solid fa-chart-line"></i></span>
                        <span class="nav-label">Toàn bộ lịch sử</span>
                    </a>
                }

            </nav>

            <div class="sidebar-section-label">Hệ thống</div>
            <nav class="sidebar-nav">

                @if (User.IsInRole("admin"))
                {
                    <a asp-controller="Users" asp-action="Index" class="nav-link-item @(ctx == "Users" ? "active" : "")">
                        <span class="nav-icon"><i class="fa-solid fa-users"></i></span>
                        <span class="nav-label">Quản lý người dùng</span>
                    </a>

                    <a asp-controller="OwnerRegistration" asp-action="Index" class="nav-link-item @(ctx == "OwnerRegistration" ? "active" : "")">
                        <span class="nav-icon"><i class="fa-solid fa-clipboard-user"></i></span>
                        <span class="nav-label">Duyệt yêu cầu</span>
                    </a>
                }

                <a asp-controller="Account" asp-action="Logout" class="nav-link-item nav-danger">
                    <span class="nav-icon"><i class="fa-solid fa-right-from-bracket"></i></span>
                    <span class="nav-label">Đăng xuất</span>
                </a>

            </nav>
        </aside>

        <div class="main-wrap">
            <header class="topbar">
                <button class="topbar-toggle" onclick="document.getElementById('sidebar').classList.toggle('collapsed')">
                    <i class="fa-solid fa-bars"></i>
                </button>
                <div class="topbar-title">@ViewData["Title"]</div>
                <div class="topbar-right">
                    <div class="topbar-user">
                        <div class="user-avatar">A</div>
                        <span class="user-name">@role</span>
                    </div>
                </div>
            </header>

            <main class="page-content">
                @if (TempData["Success"] != null)
                {
                    <div class="alert-toast toast-success">
                        <i class="fa-solid fa-circle-check"></i> @TempData["Success"]
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert-toast toast-error">
                        <i class="fa-solid fa-circle-xmark"></i> @TempData["Error"]
                    </div>
                }
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.querySelectorAll('.alert-toast').forEach(el => {
            setTimeout(() => el.style.opacity = '0', 3500);
            setTimeout(() => el.remove(), 4000);
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>