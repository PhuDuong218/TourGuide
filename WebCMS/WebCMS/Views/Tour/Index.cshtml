@* Views/Tours/Index.cshtml *@
@model List<WebCMS.Models.Tour>
@{
    ViewData["Title"] = "Quản lý Tours";
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Quản lý Tours</h1>
        <p>Tạo và sắp xếp các lộ trình tham quan từ các điểm POI</p>
    </div>
    <a href="/Tours/Create" class="btn-primary-admin">
        <i class="fa-solid fa-plus"></i> Tạo Tour mới
    </a>
</div>

@if (Model != null && Model.Any())
{
    <div class="tour-grid">
        @foreach (var tour in Model)
        {
            <div class="tour-card">
                <div class="tour-card-cover">
                    <i class="fa-solid fa-route"></i>
                </div>
                <div class="tour-card-body">
                    <div class="tour-card-name">@(tour.Name ?? "Chưa đặt tên")</div>
                    <div class="tour-card-desc">@(tour.Description ?? "Chưa có mô tả...")</div>
                    <div class="tour-card-meta">
                        <div class="tour-meta-item">
                            <i class="fa-solid fa-map-pin"></i>
                            @tour.PoiIds.Count điểm
                        </div>
                        <div class="tour-meta-item">
                            <i class="fa-regular fa-clock"></i>
                            @tour.Duration phút
                        </div>
                    </div>
                </div>
                <div class="tour-card-actions">
                    <a href="/Tours/Edit/@tour.Id" class="btn-outline-admin" style="flex:1;justify-content:center;font-size:12px">
                        <i class="fa-solid fa-pen"></i> Chỉnh sửa
                    </a>
                    <a href="/Tours/Delete/@tour.Id"
                       class="btn-icon-admin danger"
                       onclick="return confirm('Xóa tour @tour.Name?')"
                       title="Xóa">
                        <i class="fa-solid fa-trash"></i>
                    </a>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="admin-card">
        <div class="empty-state">
            <div class="empty-icon"><i class="fa-solid fa-route"></i></div>
            <h3>Chưa có Tour nào</h3>
            <p>Tạo tour đầu tiên bằng cách chọn các POI và sắp xếp lộ trình.</p>
            <a href="/Tours/Create" class="btn-primary-admin">
                <i class="fa-solid fa-plus"></i> Tạo Tour đầu tiên
            </a>
        </div>
    </div>
}
