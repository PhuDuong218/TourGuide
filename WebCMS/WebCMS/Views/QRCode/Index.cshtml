@{
    ViewData["Title"] = "Quản lý mã QR";
    // Lấy URL API từ ViewBag
    string apiUrl = ViewBag.ApiUrl ?? "";
}

<div class="admin-card" style="background: white; border-radius: 12px; padding: 20px; box-shadow: 0 2px 15px rgba(0,0,0,0.08);">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <h4 style="font-weight: 700; margin: 0;">Danh sách mã QR</h4>
        <button class="btn" style="background: #6200EE; color: white; border-radius: 8px;">+ Tạo QR mới</button>
    </div>

    <table class="table" id="qrTable" style="width: 100%; border-collapse: collapse;">
        <thead>
            <tr style="color: #6b7280; font-size: 13px; border-bottom: 2px solid #f3f4f6;">
                <th style="padding: 12px;">ID</th>
                <th style="padding: 12px;">ĐỊA ĐIỂM (POI)</th>
                <th style="padding: 12px;">GIÁ TRỊ QR</th>
                <th style="padding: 12px;">NGÀY TẠO</th>
                <th style="padding: 12px;">PREVIEW</th>
                <th style="padding: 12px; text-align: center;">XÓA</th>
            </tr>
        </thead>
        <tbody id="qrTableBody">
            <tr>
                <td colspan="6" style="text-align: center; padding: 40px;">
                    <i class="fa-solid fa-spinner fa-spin"></i> Đang tải dữ liệu từ API...
                </td>
            </tr>
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        // Lấy URL API từ C# truyền xuống
        const API_BASE_URL = '@apiUrl';

        async function loadQRCodes() {
            const tbody = document.getElementById('qrTableBody');

            try {
                // Gọi đến đúng port của API (ví dụ http://localhost:5015/api/QRCode)
                const response = await fetch(`${API_BASE_URL}/api/QRCode`);

                if (!response.ok) throw new Error('Không thể kết nối API');

                const data = await response.json();
                tbody.innerHTML = '';

                if (data.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="6" class="text-center">Chưa có dữ liệu QR</td></tr>';
                    return;
                }

                data.forEach(item => {
                    // KHỚP VỚI API: qrId, poiName, qrValue, createdAt
                    const row = `
                        <tr style="border-bottom: 1px solid #f3f4f6;">
                            <td style="padding: 12px; color: #9ca3af;">#${item.qrId}</td>
                            <td style="padding: 12px; font-weight: 600;">${item.poiName}</td>
                            <td style="padding: 12px; font-family: monospace; color: #6b7280;">${item.qrValue}</td>
                            <td style="padding: 12px; color: #6b7280;">${new Date(item.createdAt).toLocaleDateString('vi-VN')}</td>
                            <td style="padding: 12px;">
                                <img src="https://api.qrserver.com/v1/create-qr-code/?size=50x50&data=${item.qrValue}"
                                     style="width: 40px; border-radius: 4px; border: 1px solid #eee;" />
                            </td>
                            <td style="padding: 12px; text-align: center;">
                                <button onclick="deleteQR(${item.qrId})" style="color: #ef4444; border: none; background: none; cursor: pointer;">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    `;
                    tbody.insertAdjacentHTML('beforeend', row);
                });
            } catch (err) {
                tbody.innerHTML = `<tr><td colspan="6" class="text-center" style="color:red; padding:20px;">Lỗi: ${err.message}</td></tr>`;
            }
        }

        document.addEventListener('DOMContentLoaded', loadQRCodes);
    </script>
}