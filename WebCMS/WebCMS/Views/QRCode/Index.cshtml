@model dynamic
@{
    ViewData["Title"] = "Quản lý mã QR";
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Quản lý mã QR</h1>
        <p>Tạo và quản lý mã QR liên kết với từng địa điểm</p>
    </div>
    <button class="btn-primary-admin" onclick="showCreateModal()">
        <i class="fa-solid fa-plus"></i> Tạo QR mới
    </button>
</div>

<!-- Stats -->
<div class="stats-row" style="grid-template-columns:repeat(3,1fr);margin-bottom:24px">
    <div class="stat-card">
        <div class="stat-icon purple"><i class="fa-solid fa-qrcode"></i></div>
        <div>
            <div class="stat-label">Tổng mã QR</div>
            <div class="stat-value" id="statTotal">–</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green"><i class="fa-solid fa-map-pin"></i></div>
        <div>
            <div class="stat-label">POI có QR</div>
            <div class="stat-value" id="statPOI">–</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon blue"><i class="fa-solid fa-mobile-screen"></i></div>
        <div>
            <div class="stat-label">Lượt quét QR</div>
            <div class="stat-value" id="statScans">–</div>
        </div>
    </div>
</div>

<div class="admin-card">
    <div class="admin-card-header">
        <span class="admin-card-title">Danh sách mã QR</span>
        <div class="search-box">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="text" class="search-input" id="searchInput" placeholder="Tìm theo POI, mã QR...">
        </div>
    </div>
    <div class="admin-card-body">
        <table class="admin-table" id="qrTable">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Địa điểm (POI)</th>
                    <th>Giá trị QR</th>
                    <th>Ngày tạo</th>
                    <th>Preview</th>
                    <th style="width:80px;text-align:center">Xóa</th>
                </tr>
            </thead>
            <tbody id="qrBody">
                <tr>
                    <td colspan="6" style="text-align:center;color:var(--text-muted);padding:40px">
                        <i class="fa-solid fa-spinner fa-spin"></i> Đang tải...
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Create Modal -->
<div id="createModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:1000;align-items:center;justify-content:center">
    <div style="background:white;border-radius:16px;padding:32px;width:480px;max-width:90vw">
        <h3 style="font-size:16px;font-weight:800;margin-bottom:20px">Tạo mã QR mới</h3>
        <div class="form-group">
            <label class="form-label-admin">Địa điểm (POI)</label>
            <select id="selPOI" class="form-control-admin">
                <option value="">-- Chọn POI --</option>
            </select>
        </div>
        <div class="form-group">
            <label class="form-label-admin">Giá trị QR</label>
            <input type="text" id="inpQR" class="form-control-admin" placeholder="VD: QR_PHOHOA_001">
            <div class="form-hint">Chỉ dùng chữ cái, số và dấu _. Phải là duy nhất.</div>
        </div>
        <div class="form-actions">
            <button class="btn-primary-admin" onclick="createQR()">
                <i class="fa-solid fa-floppy-disk"></i> Tạo mã QR
            </button>
            <button class="btn-outline-admin" onclick="hideModal()">Hủy</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js"></script>
    <script>
        const API = '';
        let pois = [];

        async function loadQRCodes() {
            const [qrRes, visitRes] = await Promise.all([
                fetch(`${API}/api/QRCode`),
                fetch(`${API}/api/VisitHistory?limit=1000`)
            ]);
            const qrs    = await qrRes.json();
            const visits = await visitRes.json();

            const qrScans = visits.filter(v => v.scanMethod === 'QR_Scan').length;
            document.getElementById('statTotal').textContent = qrs.length;
            document.getElementById('statPOI').textContent   = new Set(qrs.map(q => q.poiID)).size;
            document.getElementById('statScans').textContent = qrScans;

            const tbody = document.getElementById('qrBody');
            if (!qrs.length) {
                tbody.innerHTML = `<tr><td colspan="6" class="empty-state" style="border:none">
                    <div class="empty-icon"><i class="fa-solid fa-qrcode"></i></div>
                    <h3>Chưa có mã QR</h3>
                    <p>Tạo mã QR để khách có thể quét và nghe thuyết minh.</p>
                </td></tr>`;
                return;
            }

            tbody.innerHTML = qrs.map(q => `
                <tr>
                    <td><span class="table-id">#${q.qrid}</span></td>
                    <td><strong>${q.poiName}</strong><br><small style="color:var(--text-muted)">POI #${q.poiID}</small></td>
                    <td><code style="background:var(--bg);padding:3px 8px;border-radius:6px;font-size:12px">${q.qrValue}</code></td>
                    <td style="color:var(--text-muted);font-size:13px">${new Date(q.createdAt).toLocaleDateString('vi-VN')}</td>
                    <td>
                        <button class="btn-outline-admin" style="font-size:12px;padding:5px 10px"
                            onclick="showQRPreview('${q.qrValue}')">
                            <i class="fa-solid fa-eye"></i> Xem QR
                        </button>
                    </td>
                    <td style="text-align:center">
                        <button class="btn-icon-admin danger" onclick="deleteQR(${q.qrid})" title="Xóa">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </td>
                </tr>
            `).join('');
        }

        async function loadPOIs() {
            const res = await fetch(`${API}/api/POI/raw`);
            pois = await res.json();
            const sel = document.getElementById('selPOI');
            sel.innerHTML = '<option value="">-- Chọn POI --</option>' +
                pois.map(p => `<option value="${p.poiid}">${p.restaurantName} (#${p.poiid})</option>`).join('');
        }

        function showCreateModal() {
            loadPOIs();
            document.getElementById('createModal').style.display = 'flex';
        }

        function hideModal() {
            document.getElementById('createModal').style.display = 'none';
            document.getElementById('selPOI').value = '';
            document.getElementById('inpQR').value  = '';
        }

        async function createQR() {
            const poiId   = parseInt(document.getElementById('selPOI').value);
            const qrValue = document.getElementById('inpQR').value.trim();
            if (!poiId || !qrValue) return alert('Vui lòng chọn POI và nhập giá trị QR.');

            const res = await fetch(`${API}/api/QRCode`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ poiId, qrValue })
            });

            if (res.ok) {
                hideModal();
                loadQRCodes();
            } else {
                const err = await res.json();
                alert(err.message || 'Lỗi tạo QR');
            }
        }

        async function deleteQR(id) {
            if (!confirm('Xóa mã QR này?')) return;
            await fetch(`${API}/api/QRCode/${id}`, { method: 'DELETE' });
            loadQRCodes();
        }

        function showQRPreview(value) {
            const modal = document.createElement('div');
            modal.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:2000;display:flex;align-items:center;justify-content:center';
            modal.innerHTML = `
                <div style="background:white;border-radius:16px;padding:32px;text-align:center;min-width:280px">
                    <h4 style="font-weight:800;margin-bottom:16px">${value}</h4>
                    <div id="qrCanvas" style="display:flex;justify-content:center;margin-bottom:16px"></div>
                    <p style="font-size:12px;color:#888;margin-bottom:16px">In hoặc chụp màn hình để dùng</p>
                    <button onclick="this.closest('div[style*=fixed]').remove()"
                        style="background:#6366f1;color:white;border:none;border-radius:8px;padding:10px 24px;cursor:pointer;font-weight:600">
                        Đóng
                    </button>
                </div>`;
            document.body.appendChild(modal);
            new QRCode(document.getElementById('qrCanvas'), {
                text: value, width: 200, height: 200,
                colorDark: '#0f172a', colorLight: '#ffffff'
            });
        }

        // Search
        document.getElementById('searchInput')?.addEventListener('input', function() {
            const q = this.value.toLowerCase();
            document.querySelectorAll('#qrTable tbody tr').forEach(row => {
                row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
            });
        });

        loadQRCodes();
    </script>
}
