@model List<WebCMS.Models.VisitHistory>
@{
    ViewData["Title"] = "Lịch sử truy cập";
}

<div class="admin-card" style="background: white; border-radius: 12px; padding: 20px; box-shadow: 0 2px 15px rgba(0,0,0,0.08);">
    <h4 style="font-weight: 700; margin-bottom: 20px;">Nhật ký quét mã QR</h4>

    <table class="table" style="width: 100%; border-collapse: collapse;">
        <thead>
            <tr style="color: #6b7280; font-size: 13px; border-bottom: 2px solid #f3f4f6;">
                <th style="padding: 12px;">THỜI GIAN</th>
                <th style="padding: 12px;">ĐỊA ĐIỂM (POI)</th>
                <th style="padding: 12px;">NGƯỜI DÙNG</th>
                <th style="padding: 12px;">THIẾT BỊ</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr style="border-bottom: 1px solid #f3f4f6;">
                        <td style="padding: 12px; color: #6b7280;">@item.VisitTime.ToString("dd/MM/yyyy HH:mm")</td>
                        <td style="padding: 12px; font-weight: 600;">@item.POIName</td>
                        <td style="padding: 12px;">@item.Username</td>
                        <td style="padding: 12px;">
                            <span class="badge bg-light text-dark">
                                <i class="fa-solid fa-qrcode"></i> @(item.ScanMethod ?? "QR Scan")
                            </span>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4" class="text-center" style="padding:40px; color: #999;">
                        Chưa có lịch sử hoặc lỗi kết nối API.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>