@{
    ViewData["Title"] = "Quản lý người dùng";
    string apiUrl = ViewBag.ApiUrl ?? "https://gzm4vrwg-7054.asse.devtunnels.ms/api/"; // Nhớ cấu hình đúng URL API
}

<div class="admin-card" style="background: white; border-radius: 12px; padding: 20px; box-shadow: 0 2px 15px rgba(0,0,0,0.08);">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <h4 style="font-weight: 700; margin: 0;">Danh sách tài khoản</h4>
        <button class="btn" style="background: #6200EE; color: white; border-radius: 8px;" onclick="openAddModal()">
            <i class="fa-solid fa-plus"></i> Thêm người dùng
        </button>
    </div>

    <table class="table table-hover" id="userTable" style="width: 100%; border-collapse: collapse;">
        <thead>
            <tr style="color: #6b7280; font-size: 13px; border-bottom: 2px solid #f3f4f6;">
                <th style="padding: 12px;">ID</th>
                <th style="padding: 12px;">TÀI KHOẢN</th>
                <th style="padding: 12px;">EMAIL</th>
                <th style="padding: 12px;">VAI TRÒ</th>
                <th style="padding: 12px;">NGÀY TẠO</th>
                <th style="padding: 12px; text-align: center;">THAO TÁC</th>
            </tr>
        </thead>
        <tbody id="userTableBody">
            <tr><td colspan="6" class="text-center" style="padding:40px;">Đang tải dữ liệu...</td></tr>
        </tbody>
    </table>
</div>

<div class="modal fade" id="userModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 12px; border: none; box-shadow: 0 10px 30px rgba(0,0,0,0.1);">
            <div class="modal-header" style="border-bottom: 1px solid #f3f4f6;">
                <h5 class="modal-title" id="modalTitle" style="font-weight: 700;">Thêm người dùng mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="userForm" onsubmit="saveUser(event)">
                <div class="modal-body">
                    <input type="hidden" id="userId" />

                    <div class="mb-3">
                        <label class="form-label" style="font-size: 13px; font-weight: 600; color: #4b5563;">Tên đăng nhập *</label>
                        <input type="text" class="form-control" id="userName" required placeholder="Nhập username" style="border-radius: 8px;" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label" style="font-size: 13px; font-weight: 600; color: #4b5563;">Email *</label>
                        <input type="email" class="form-control" id="userEmail" required placeholder="example@email.com" style="border-radius: 8px;" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label" style="font-size: 13px; font-weight: 600; color: #4b5563;">Mật khẩu <span id="pwdHint"></span></label>
                        <input type="password" class="form-control" id="userPassword" placeholder="Nhập mật khẩu" style="border-radius: 8px;" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label" style="font-size: 13px; font-weight: 600; color: #4b5563;">Vai trò *</label>
                        <select class="form-select" id="userRole" required style="border-radius: 8px;">
                            <option value="user">Người dùng (User)</option>
                            <option value="owner">Chủ quán (Owner)</option>
                            <option value="admin">Quản trị viên (Admin)</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer" style="border-top: 1px solid #f3f4f6;">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal" style="border-radius: 8px;">Hủy</button>
                    <button type="submit" class="btn btn-primary" style="background: #6200EE; border: none; border-radius: 8px;">Lưu thông tin</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Xử lý đường dẫn API an toàn (Tránh lỗi dư hoặc thiếu dấu gạch chéo)
        const rawUrl = '@apiUrl';
        const baseUrl = rawUrl.endsWith('/') ? rawUrl : rawUrl + '/';
        const userApiUrl = baseUrl + 'User'; // Link gọi: https://.../api/User

        let isEditing = false; // Biến kiểm tra xem đang Thêm hay Sửa

        // 1. HÀM TẢI DANH SÁCH (READ)
        async function loadUsers() {
            const tbody = document.getElementById('userTableBody');
            try {
                const response = await fetch(userApiUrl);
                if (!response.ok) throw new Error("Lỗi Server");

                const data = await response.json();
                tbody.innerHTML = '';

                if (data.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="6" class="text-center" style="padding:20px;">Chưa có người dùng nào.</td></tr>';
                    return;
                }

                data.forEach(u => {
                    // Bao lô mọi trường hợp viết hoa/thường từ C# JSON
                    const id = u.userID || u.userId || u.id || '';
                    const username = u.userName || u.username || '';
                    const email = u.email || '';
                    const role = u.role || 'user';
                    const date = u.createdAt || u.createdDate ? new Date(u.createdAt || u.createdDate).toLocaleDateString('vi-VN') : 'N/A';

                    // Lối thoát các dấu nháy để truyền vào hàm sửa
                    const safeUsername = username.replace(/'/g, "\\'");
                    const safeEmail = email.replace(/'/g, "\\'");

                    // Nút Vai trò hiển thị màu mè cho đẹp
                    let roleBadge = `<span class="badge bg-secondary">User</span>`;
                    if (role.toLowerCase() === 'admin') roleBadge = `<span class="badge bg-danger">Admin</span>`;
                    if (role.toLowerCase() === 'owner') roleBadge = `<span class="badge bg-primary">Owner</span>`;

                    const row = `
                        <tr style="border-bottom: 1px solid #f3f4f6; vertical-align: middle;">
                            <td style="padding: 12px; font-family: monospace; color: #6b7280;">#${id}</td>
                            <td style="padding: 12px; font-weight: 600; color: #111827;">${username}</td>
                            <td style="padding: 12px; color: #4b5563;">${email}</td>
                            <td style="padding: 12px;">${roleBadge}</td>
                            <td style="padding: 12px; color: #6b7280; font-size: 13px;">${date}</td>
                            <td style="padding: 12px; text-align: center;">
                                <button class="btn btn-sm btn-light" style="color: #3b82f6; margin-right: 5px;"
                                        onclick="openEditModal('${id}', '${safeUsername}', '${safeEmail}', '${role}')" title="Sửa">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </button>
                                <button class="btn btn-sm btn-light" style="color: #ef4444;"
                                        onclick="deleteUser('${id}')" title="Xóa">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </td>
                        </tr>`;
                    tbody.insertAdjacentHTML('beforeend', row);
                });
            } catch (e) {
                console.error(e);
                tbody.innerHTML = '<tr><td colspan="6" class="text-center" style="color:red; padding:20px;">Lỗi kết nối API. Không thể lấy dữ liệu!</td></tr>';
            }
        }

        // 2. MỞ MODAL THÊM MỚI
        function openAddModal() {
            isEditing = false;
            document.getElementById('modalTitle').innerText = "Thêm người dùng mới";
            document.getElementById('userForm').reset();
            document.getElementById('userId').value = "";
            document.getElementById('userPassword').required = true; // Bắt buộc nhập MK
            document.getElementById('pwdHint').innerText = "(*)";

            new bootstrap.Modal(document.getElementById('userModal')).show();
        }

        // 3. MỞ MODAL SỬA
        function openEditModal(id, username, email, role) {
            isEditing = true;
            document.getElementById('modalTitle').innerText = "Sửa thông tin người dùng";

            // Đổ dữ liệu cũ vào Form
            document.getElementById('userId').value = id;
            document.getElementById('userName').value = username;
            document.getElementById('userEmail').value = email;
            document.getElementById('userRole').value = role.toLowerCase();

            // Sửa thì mật khẩu không bắt buộc (bỏ trống là không đổi)
            document.getElementById('userPassword').value = "";
            document.getElementById('userPassword').required = false;
            document.getElementById('pwdHint').innerText = "(Bỏ trống nếu không muốn đổi)";

            new bootstrap.Modal(document.getElementById('userModal')).show();
        }

        // 4. HÀM LƯU (CREATE & UPDATE)
        async function saveUser(e) {
            e.preventDefault(); // Chặn tải lại trang

            // Lấy dữ liệu từ form
            const id = document.getElementById('userId').value;
            const payload = {
                username: document.getElementById('userName').value,
                email: document.getElementById('userEmail').value,
                role: document.getElementById('userRole').value
            };

            const pwd = document.getElementById('userPassword').value;
            if (pwd) payload.password = pwd; // Chỉ gửi mật khẩu nếu có nhập

            // Nếu đang sửa thì thêm ID vào để Server biết
            if (isEditing) payload.userId = id;

            try {
                const url = isEditing ? `${userApiUrl}/${id}` : userApiUrl;
                const method = isEditing ? 'PUT' : 'POST';

                const response = await fetch(url, {
                    method: method,
                    headers: {
                        'Content-Type': 'application/json'
                        // 'Authorization': 'Bearer ' + token // (Mở ghi chú dòng này nếu API của bạn bắt buộc kèm Token)
                    },
                    body: JSON.stringify(payload)
                });

                if (response.ok) {
                    alert(isEditing ? "Cập nhật thành công!" : "Thêm mới thành công!");
                    bootstrap.Modal.getInstance(document.getElementById('userModal')).hide();
                    loadUsers(); // Load lại bảng
                } else {
                    const err = await response.text();
                    alert("Có lỗi xảy ra: " + err);
                }
            } catch (error) {
                alert("Lỗi kết nối đến Server!");
            }
        }

        // 5. HÀM XÓA (DELETE)
        async function deleteUser(id) {
            if (!confirm("Bạn có chắc chắn muốn xóa người dùng này vĩnh viễn?")) return;

            try {
                const response = await fetch(`${userApiUrl}/${id}`, {
                    method: 'DELETE'
                    // headers: { 'Authorization': 'Bearer ' + token } // Tương tự, mở nếu cần token
                });

                if (response.ok) {
                    alert("Đã xóa người dùng!");
                    loadUsers(); // Refresh lại bảng
                } else {
                    alert("Xóa thất bại!");
                }
            } catch (error) {
                alert("Lỗi kết nối đến Server!");
            }
        }

        // Tự động tải dữ liệu khi trang vừa mở
        document.addEventListener('DOMContentLoaded', loadUsers);
    </script>
}