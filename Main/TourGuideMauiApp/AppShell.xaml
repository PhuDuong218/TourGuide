<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:TourGuideMauiApp.Views"
       x:Class="TourGuideMauiApp.AppShell">

    <TabBar>
        <Tab Title="Danh sách" Icon="dotnet_bot.png">
            <ShellContent ContentTemplate="{DataTemplate views:MainPage}" />
        </Tab>
        <Tab Title="Bản đồ" Icon="dotnet_bot.png" Route="MapPage">
            <ShellContent ContentTemplate="{DataTemplate views:MapPage}" />
        </Tab>
        <Tab Title="Quét mã" Icon="dotnet_bot.png">
            <ShellContent ContentTemplate="{DataTemplate views:ScannerPage}" />
        </Tab>
    </TabBar>
</Shell>