<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:TourGuideMauiApp.Views"
       x:Class="TourGuideMauiApp.AppShell">

    <TabBar>
        <Tab Title="Trang chủ" Icon="icon_list.png">
            <ShellContent ContentTemplate="{DataTemplate views:MainPage}" />
        </Tab>

        <Tab Title="Bản đồ" Icon="icon_map.png" Route="MapPage">
            <ShellContent ContentTemplate="{DataTemplate views:MapPage}" />
        </Tab>

        <Tab Title="Quét mã" Icon="icon_qr.png">
            <ShellContent ContentTemplate="{DataTemplate views:ScannerPage}" />
        </Tab>

        <Tab Title="Cài đặt" Icon="icon_settings.png">
            <ShellContent ContentTemplate="{DataTemplate views:SettingsPage}" />
        </Tab>
    </TabBar>

</Shell>