<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourGuideMauiApp.Views.SettingsPage"
             Title="Cài đặt" BackgroundColor="#F8F9FA">
    <ScrollView>
        <VerticalStackLayout Spacing="25" Padding="20,30">

            <VerticalStackLayout Spacing="12">
                <Label Text="NGÔN NGỮ HỆ THỐNG" FontSize="12" TextColor="#6C757D" FontAttributes="Bold" Margin="5,0"/>
                <Border BackgroundColor="White" Padding="20" StrokeShape="RoundRectangle 16" StrokeThickness="0">
                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="10">
                        <Button x:Name="btnVI" Text="VN" Clicked="OnLangViTapped" HeightRequest="60" CornerRadius="12"/>
                        <Button x:Name="btnEN" Text="EN" Grid.Column="1" Clicked="OnLangEnTapped" HeightRequest="60" CornerRadius="12"/>
                        <Button x:Name="btnFR" Text="FR" Grid.Column="2" Clicked="OnLangFrTapped" HeightRequest="60" CornerRadius="12"/>
                        <Button x:Name="btnJA" Text="JA" Grid.Column="3" Clicked="OnLangJaTapped" HeightRequest="60" CornerRadius="12"/>
                    </Grid>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="12">
                <Label Text="THUYẾT MINH &amp; ÂM THANH" FontSize="12" TextColor="#6C757D" FontAttributes="Bold" Margin="5,0"/>
                <Border BackgroundColor="White" Padding="20" StrokeShape="RoundRectangle 16" StrokeThickness="0">
                    <VerticalStackLayout Spacing="20">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0">
                                <Label Text="Tự động phát thuyết minh" FontAttributes="Bold" FontSize="16"/>
                                <Label Text="Phát âm thanh khi đến gần POI" FontSize="12" TextColor="#888"/>
                            </VerticalStackLayout>
                            <Switch x:Name="switchAutoPlay" Grid.Column="1" Toggled="OnAutoPlayToggled" OnColor="#6200EE"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#F0F0F0"/>

                        <VerticalStackLayout Spacing="10">
                            <Label Text="Tốc độ giọng đọc" FontAttributes="Bold" FontSize="16"/>
                            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="10">
                                <Button x:Name="btnS05" Text="0.5x" Clicked="OnSpeed05Tapped" CornerRadius="10"/>
                                <Button x:Name="btnS10" Text="1.0x" Grid.Column="1" Clicked="OnSpeed10Tapped" CornerRadius="10"/>
                                <Button x:Name="btnS15" Text="1.5x" Grid.Column="2" Clicked="OnSpeed15Tapped" CornerRadius="10"/>
                                <Button x:Name="btnS20" Text="2.0x" Grid.Column="3" Clicked="OnSpeed20Tapped" CornerRadius="10"/>
                            </Grid>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <Border BackgroundColor="White" Padding="20" StrokeShape="RoundRectangle 16" StrokeThickness="0">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnRegisterOwnerTapped"/>
                    </Grid.GestureRecognizers>
                    <Label Grid.Column="0" Text="🏪" FontSize="24" VerticalOptions="Center" Margin="0,0,15,0"/>
                    <Label Grid.Column="1" Text="Đăng ký trở thành chủ quán" FontAttributes="Bold" VerticalOptions="Center" FontSize="15"/>
                    <Label Grid.Column="2" Text="❯" TextColor="#CCC" VerticalOptions="Center"/>
                </Grid>
            </Border>

            <VerticalStackLayout HorizontalOptions="Center" Margin="0,20">
                <Label Text="Hệ thống TourGuide" HorizontalOptions="Center" TextColor="#ADB5BD" FontSize="13"/>
                <Label Text="Phiên bản 1.0.0" HorizontalOptions="Center" TextColor="#CED4DA" FontSize="11"/>
            </VerticalStackLayout>
            <Button Text="Đăng xuất khỏi tài khoản" 
                    BackgroundColor="#ef4444" 
                    TextColor="White" 
                    CornerRadius="8" 
                    Margin="0,20,0,0"
                    FontAttributes="Bold"
                    Clicked="OnLogoutClicked" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>