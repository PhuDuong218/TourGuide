<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourGuideMauiApp.Views.LoginPage"
             Title="Tài khoản"
             BackgroundColor="#f4f7fe">

    <ScrollView>
        <VerticalStackLayout Spacing="25" Padding="30,50,30,30" VerticalOptions="Center">

            <Image Source="dotnet_bot.png" HeightRequest="100" HorizontalOptions="Center" />
            <Label Text="TourGuide" FontSize="28" FontAttributes="Bold" TextColor="#004581" HorizontalOptions="Center" />
            <Label Text="Đăng nhập để lưu điểm đến yêu thích!" FontSize="14" TextColor="Gray" HorizontalOptions="Center" Margin="0,-15,0,20"/>

            <Border Stroke="Transparent" Padding="20" BackgroundColor="White">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Opacity="0.1" Radius="10" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="15">
                    <Entry x:Name="txtUsername" Placeholder="Tên đăng nhập" PlaceholderColor="Gray" />
                    <Entry x:Name="txtPassword" Placeholder="Mật khẩu" IsPassword="True" PlaceholderColor="Gray" />

                    <Button Text="Đăng nhập" 
                            BackgroundColor="#004581" 
                            TextColor="White" 
                            CornerRadius="8" 
                            FontAttributes="Bold"
                            Clicked="OnLoginClicked" />
                </VerticalStackLayout>
            </Border>

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                <Label Text="Chưa có tài khoản?" TextColor="Gray" VerticalOptions="Center"/>
                <Label Text="Đăng ký ngay" TextColor="#004581" FontAttributes="Bold" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnRegisterTapped" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,10" />

            <Button Text="Tiếp tục với tư cách Khách" 
                    BackgroundColor="Transparent" 
                    TextColor="Gray" 
                    BorderColor="Gray"
                    BorderWidth="1"
                    CornerRadius="8" 
                    Clicked="OnGuestClicked" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>