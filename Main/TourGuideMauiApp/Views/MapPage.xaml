<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui"
    x:Class="TourGuideMauiApp.Views.MapPage"
    Title="Bản đồ du lịch">

    <Grid>

        <!-- ── Bản đồ nền ── -->
        <mapsui:MapControl x:Name="mapView"/>

        <!-- ── Nút góc trên phải ── -->
        <VerticalStackLayout
            VerticalOptions="Start"
            HorizontalOptions="End"
            Margin="10,48,10,0"
            Spacing="8">
            <Button Text="📍 Tải địa điểm"
                    Clicked="OnRefreshMapClicked"
                    BackgroundColor="#6200EE" TextColor="White"
                    CornerRadius="20" Padding="14,8" FontSize="13"/>
            <Button Text="🎯 Vị trí của tôi"
                    Clicked="OnMyLocationClicked"
                    BackgroundColor="#03A9F4" TextColor="White"
                    CornerRadius="20" Padding="14,8" FontSize="13"/>
        </VerticalStackLayout>

        <!-- ── Gợi ý POI gần nhất ── -->
        <Border x:Name="nearestPoiPanel"
        IsVisible="False"
        VerticalOptions="Start"
        HorizontalOptions="Start" 
        Margin="15,50,0,0"
        BackgroundColor="White"
        StrokeThickness="0"
        WidthRequest="220"
        StrokeShape="RoundRectangle 15">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.1"/>
            </Border.Shadow>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnNearestPoiTapped"/>
            </Border.GestureRecognizers>

            <Grid ColumnDefinitions="Auto,*" Padding="10" ColumnSpacing="10">
                <Label Grid.Column="0" Text="📍" FontSize="18" VerticalOptions="Center"/>
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                    <Label Text="Gần bạn" FontSize="10" TextColor="#888" FontAttributes="Bold"/>
                    <Label x:Name="nearestPoiLabel" Text="..." TextColor="#1A1A2E" FontSize="12" FontAttributes="Bold" LineBreakMode="TailTruncation"/>
                </VerticalStackLayout>
            </Grid>
        </Border>

        <!-- ── Loading overlay ── -->
        <Border x:Name="loadingOverlay"
                IsVisible="False"
                BackgroundColor="#CC000000"
                StrokeShape="RoundRectangle 12"
                Padding="28,18"
                HorizontalOptions="Center"
                VerticalOptions="Center">
            <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                <ActivityIndicator x:Name="loadingIndicator"
                                   IsRunning="False" Color="White"
                                   WidthRequest="36" HeightRequest="36"/>
                <Label x:Name="loadingLabel"
                       Text="Đang tải..." TextColor="White"
                       FontSize="14" HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Border>

        <!-- ══ Bottom Sheet ══ -->
        <Border x:Name="poiBottomSheet"
                IsVisible="False"
                VerticalOptions="End"
                BackgroundColor="White"
                StrokeShape="RoundRectangle 24,24,0,0"
                StrokeThickness="0"
                Padding="0,10,0,30">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,-5" Radius="15" Opacity="0.15"/>
            </Border.Shadow>

            <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="12">

                <BoxView Grid.Row="0" WidthRequest="40" HeightRequest="5" BackgroundColor="#E0E0E0" CornerRadius="2.5" HorizontalOptions="Center"/>

                <Border Grid.Row="1" Margin="20,5,20,0" HeightRequest="160" StrokeShape="RoundRectangle 16" StrokeThickness="0">
                    <Image x:Name="poiImage" Aspect="AspectFill" BackgroundColor="#F5F5F5"/>
                </Border>

                <VerticalStackLayout Grid.Row="2" Margin="20,0,20,0" Spacing="6">
                    <Label x:Name="poiName" FontSize="22" FontAttributes="Bold" TextColor="#111827" LineBreakMode="TailTruncation"/>

                    <HorizontalStackLayout Spacing="5">
                        <Label Text="📍" FontSize="14" VerticalOptions="Center"/>
                        <Label x:Name="poiAddress" FontSize="14" TextColor="#6B7280" LineBreakMode="TailTruncation" MaxLines="1"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="5">
                        <Label Text="📏" FontSize="14" VerticalOptions="Center"/>
                        <Label x:Name="poiDistance" FontSize="14" TextColor="#6200EE" FontAttributes="Bold"/>
                    </HorizontalStackLayout>

                    <Label x:Name="poiDescription" FontSize="14" TextColor="#4B5563" MaxLines="3" LineHeight="1.3" LineBreakMode="TailTruncation" Margin="0,5,0,0"/>
                </VerticalStackLayout>

                <Grid Grid.Row="3" Margin="20,10,20,0" ColumnDefinitions="*, Auto" ColumnSpacing="15" VerticalOptions="Center">

                    <Border Grid.Column="0" BackgroundColor="#6200EE" StrokeShape="RoundRectangle 25" HeightRequest="50" StrokeThickness="0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnPlayPauseTapped"/>
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10" InputTransparent="True">
                            <Label x:Name="playPauseIcon" Text="▶" FontSize="20" TextColor="White" VerticalOptions="Center"/>
                            <Label x:Name="playStatusText" Text="Phát thuyết minh" FontSize="16" TextColor="White" FontAttributes="Bold" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Border>

                    <Border Grid.Column="1" BackgroundColor="#F3F4F6" StrokeShape="RoundRectangle 25" WidthRequest="50" HeightRequest="50" StrokeThickness="0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCloseBottomSheet"/>
                        </Border.GestureRecognizers>
                        <Label Text="✕" FontSize="18" TextColor="#374151" HorizontalOptions="Center" VerticalOptions="Center" FontAttributes="Bold"/>
                    </Border>

                </Grid>
            </Grid>
        </Border>

    </Grid>
</ContentPage>
